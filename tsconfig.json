{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": "src",
		"paths": {
			"@/*": ["./*"],
			"@config": ["config/*"],
			"@icons": ["icons/*"],
			"@utils/*": ["utils/*"],
			"@components/*": ["components/*"],
			"@layouts/*": ["layouts/*"],
			"@pages/*": ["pages/*"],
			"@styles/*": ["styles/*"]
		}
	},
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["node_modules", "**/node_modules/*", ".vscode", "dist"]
}

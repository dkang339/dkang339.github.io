---
import { Icon } from 'astro-icon/components';

const { href, imgSrc, title, summary, pdf, github } = Astro.props;
const isVideo = typeof imgSrc === 'string' && /\.(mp4|webm|ogg)$/i.test(imgSrc.split('?')[0]);
---

<article class="project-card">
	<a class="project-card__main" href={href}>
		<div class="project-card__media">
			{isVideo ? (
				<video class="project-card__img" autoplay muted loop playsinline preload="metadata" aria-label={title}>
					<source src={imgSrc} type="video/mp4" />
				</video>
			) : (
				<img class="project-card__img" src={imgSrc} alt={title} loading="lazy" decoding="async" />
			)}
		</div>
		<div class="project-card__body">
			<h3 class="project-card__title">{title}</h3>
			{summary && <p class="project-card__summary">{summary}</p>}
		</div>
	</a>
	{(pdf || github) && (
		<div class="project-card__actions">
			{pdf && (
				<a href={pdf} target="_blank" rel="noopener" class="project-card__action" aria-label={`${title} PDF`}>
					<Icon name="mdi:file-document-outline" /> View PDF
				</a>
			)}
			{github && (
				<a href={github} target="_blank" rel="noopener" class="project-card__action" aria-label={`${title} GitHub`}>
					<Icon name="mdi:github" /> GitHub
				</a>
			)}
		</div>
	)}
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		background-color: var(--theme-surface-1);
		color: var(--theme-on-surface-1);
		border-radius: var(--theme-shape-radius);
		overflow: hidden;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
	}
	.project-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12);
	}
	.project-card__main {
		color: inherit;
		text-decoration: none;
	}
	.project-card__media {
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background-color: var(--theme-surface-2);
	}
	.project-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform var(--theme-transition);
	}
	.project-card:hover .project-card__img {
		transform: scale(1.03);
	}
	.project-card__media video.project-card__img {
		transform: scale(1.23);
	}
	.project-card:hover .project-card__media video.project-card__img {
		transform: scale(1.27);
	}
	.project-card__body {
		padding: 1rem 1.25rem 1.25rem;
	}
	.project-card__title {
		margin: 0;
		font-family: var(--theme-font-family-sans);
		font-size: var(--font-size-md);
	}
	.project-card__summary {
		margin: 0.5rem 0 0;
		font-size: var(--font-size-sm);
		opacity: 0.8;
	}
	.project-card__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0 1.25rem 1.25rem;
		margin-top: auto;
	}
	.project-card__action {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.25rem 0.45rem;
		color: inherit;
		font-size: var(--font-size-sm);
		text-decoration: none;
		border-radius: var(--theme-button-border-radius);
		opacity: 0.78;
		transition:
			background-color var(--theme-transition),
			color var(--theme-transition),
			opacity var(--theme-transition);
	}
	.project-card__action:hover,
	.project-card__action:focus-visible {
		background-color: var(--theme-primary);
		color: var(--theme-on-primary);
		opacity: 1;
	}
	.project-card__action [data-icon] {
		font-size: 1.1em;
	}
</style>

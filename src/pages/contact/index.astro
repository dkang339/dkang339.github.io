---
import { Icon } from 'astro-icon/components';
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

const seo = {
	title: 'Contact | Dayoung Kang',
	description: 'Get in touch with Dayoung Kang.',
};
---

<Layout {seo}>
	<Container narrow>
		<section class="page-header">
			<h1>Contact Me</h1>
		</section>

		<section class="contact">
			<p class="contact__message">
				Open to research collaborations and related professional opportunities.
				Feel free to reach out to discuss ideas or connect.
			</p>

			<ul class="contact__list">
				<li>
					<a href="mailto:dkang339@gatech.edu" class="contact__link">
						<Icon name="mdi:email-outline" />
						<span>dkang339@gatech.edu</span>
					</a>
				</li>
				<li>
					<a
						href="https://www.linkedin.com/in/dayoung-kang-7323a828b"
						target="_blank"
						rel="noopener"
						class="contact__link"
					>
						<Icon name="mdi:linkedin" />
						<span>linkedin.com/in/dayoung-kang-7323a828b</span>
					</a>
				</li>
			</ul>
		</section>
	</Container>
</Layout>

<style>
	.page-header {
		margin: var(--section-margin) auto 1rem;
	}
	.page-header h1::after {
		content: '';
		display: block;
		width: 6rem;
		height: 3px;
		background-color: var(--theme-primary);
		margin-top: 0.5rem;
		border-radius: 2px;
	}
	.contact {
		margin: 0 auto var(--section-margin);
	}
	.contact__message {
		font-size: 1.05rem;
		line-height: 1.7;
		margin: 0 0 2rem;
	}
	.contact__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.contact__link {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: inherit;
		padding: 0.6rem 1rem;
		background-color: var(--theme-surface-1);
		border-radius: var(--theme-button-border-radius);
		transition: background-color var(--theme-transition);
		width: fit-content;
	}
	.contact__link:hover {
		background-color: var(--theme-surface-2);
	}
	.contact__link [data-icon] {
		font-size: 1.25em;
	}
</style>

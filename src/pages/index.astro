---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { Container } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';
import ProjectCard from '../components/cards/ProjectCard.astro';

const seo = {
	title: 'Dayoung Kang',
	description: 'Personal website of Dayoung Kang, PhD student in Computational Science and Engineering at Georgia Tech.',
};

const projects = (await getCollection('projects')).sort(
	(a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);

const publications = [
	{
		title: 'Condition-based fatigue life monitoring of a high-pressure hydrogen storage vessel using a reduced basis digital twin',
		authors: 'D. Kang, S. Kang, B. Kim, K. Lee',
		venue: 'Engineering Structures',
		link: 'https://www.sciencedirect.com/science/article/pii/S0141029625005875',
		year: 2025,
	},
	{
		title: 'Multifidelity linear regression for scientific machine learning from scarce data',
		authors: 'E. Qian, D. Kang, V. Sella, and A. Chaudhuri',
		venue: 'Foundations of Data Science',
		link: 'https://www.aimsciences.org/article/doi/10.3934/fods.2024049',
		year: 2025,
	},
	{
		title: 'Inverse Identification of a Constitutive Model for High-Speed Forming Simulation: An Application to Electromagnetic Metal Forming',
		authors: 'D. Kang, H. G. Noh, J. Kim, and K. Lee',
		venue: 'Materials',
		link: 'https://doi.org/10.3390/ma15207179',
		year: 2022,
	},
	{
		title: 'Reliability-based Design Optimization of a High-Pressure Hydrogen Storage Vessel Using a Static Condensation Reduced Basis Element Method',
		authors: 'D. Kang, T. M. Pham, and K. Lee',
		venue: 'Transactions of the Korean Society of Mechanical Engineers, A',
		link: 'https://doi.org/10.3795/KSME-A.2022.46.2.127',
		year: 2022,
	},
	{
		title: 'On the Effect of Air-Simulated Side-Jets on the Aerodynamic Characteristics of a Missile by Multi-Fidelity Modeling',
		authors: 'S. Kang, D. Kang, and K. Lee',
		venue: 'Journal of the Korean Society for Aeronautical & Space Sciences',
		link: 'https://doi.org/10.5139/JKSAS.2021.49.2.95',
		year: 2021,
	},
].sort((a, b) => b.year - a.year);
---

<Layout {seo}>
	<Container>
		<section class="hero">
			<div class="hero__photo-wrap">
				<img src="/profile.jpeg" alt="Dayoung Kang" class="hero__photo" />
			</div>
			<div class="hero__text">
				<h1 class="hero__title">About Me</h1>
				<p>
					I am a PhD student in Computational Science and Engineering (home unit in Aerospace
					Engineering) at Georgia Tech. I joined
					<a href="https://www.elizabethqian.com/research/ace-group" target="_blank" rel="noopener">ACE group</a>
					in Fall 2023 and have been working with
					<a href="https://www.elizabethqian.com/" target="_blank" rel="noopener">Dr. Elizabeth Qian</a>.
					Before joining the group, I received my master's in Aerospace Engineering, primarily
					working on surrogate modeling for engineering applications. My current research focuses
					on methodological development in multifidelity machine learning, leveraging both
					expensive high- and cheap low-fidelity data.
				</p>
				<div class="hero__links">
					<a href="/CV_DKang.pdf" target="_blank" rel="noopener">
						<Icon name="mdi:file-document-outline" /> CV (PDF)
					</a>
					<a href="mailto:dkang339@gatech.edu">
						<Icon name="mdi:email-outline" /> Email
					</a>
					<a href="https://github.com/dkang339" target="_blank" rel="noopener">
						<Icon name="mdi:github" /> GitHub
					</a>
					<a href="https://www.linkedin.com/in/dayoung-kang-7323a828b" target="_blank" rel="noopener">
						<Icon name="mdi:linkedin" /> LinkedIn
					</a>
				</div>

				<div class="education">
					<h3 class="education__title">Education</h3>
					<ul class="education-list">
						<li>
							<div class="education__row">
								<div>
									<strong>Georgia Institute of Technology</strong> — PhD in Computational Science and Engineering
								</div>
								<div class="education__date">Aug 2023 – Present</div>
							</div>
						</li>
						<li>
							<div class="education__row">
								<div>
									<strong>Georgia Institute of Technology</strong> — Master in Computational Science and Engineering
								</div>
								<div class="education__date">Jan 2026 – May 2026</div>
							</div>
						</li>
						<li>
							<div class="education__row">
								<div>
									<strong>Pusan National University</strong> — Master in Aerospace Engineering
								</div>
								<div class="education__date">Sep 2020 – Aug 2022</div>
							</div>
						</li>
						<li>
							<div class="education__row">
								<div>
									<strong>Pusan National University</strong> — Bachelor in Aerospace Engineering
								</div>
								<div class="education__date">Mar 2016 – Aug 2020</div>
							</div>
						</li>
					</ul>
				</div>
			</div>
		</section>
	</Container>

	<Container>
		<section class="home-section">
			<header class="home-section__header">
				<h2>Projects</h2>
				<a class="home-section__more" href="/projects">All projects →</a>
			</header>
			<div class="projects-grid">
				{projects.map((p) => (
					<ProjectCard
						href={`/projects/${p.id}/`}
						imgSrc={p.data.thumbnail}
						title={p.data.title}
						summary={p.data.summary}
					/>
				))}
			</div>
		</section>
	</Container>

	<Container>
		<section class="home-section">
			<header class="home-section__header">
				<h2>Publications</h2>
				<a class="home-section__more" href="/pubs">All publications →</a>
			</header>
			<ul class="pubs-list">
				{publications.map((p) => (
					<li class="pubs-list__item">
						<a href={p.link} target="_blank" rel="noopener noreferrer" class="pubs-list__title">
							{p.title}
						</a>
						<div class="pubs-list__authors" set:html={p.authors.split('D. Kang').map((c, i) => i > 0 ? `<span class="me">D. Kang</span>${c}` : c).join('')}></div>
						<div class="pubs-list__venue">{p.venue} ({p.year})</div>
					</li>
				))}
			</ul>
		</section>
	</Container>

	<Container>
		<section class="home-section">
			<header class="home-section__header">
				<h2>Teaching & Mentoring</h2>
				<a class="home-section__more" href="/teaching">Details →</a>
			</header>
			<ul class="teaching-list">
				<li><strong>Teaching Assistant</strong> — Numerical Analysis and Algorithms · Georgia Tech · Spring 2024, Spring 2025</li>
				<li><strong>Teaching Assistant</strong> — Introduction to IoT-based Digital Twin · Pusan National University · Fall 2022</li>
				<li><strong>Research Mentor</strong> — Multifidelity Neural Network Project (PURA) · Fall 2024 – Fall 2025</li>
				<li><strong>Research Mentor</strong> — Multifidelity Linear Regression Project (SURE) · Summer 2025</li>
			</ul>
		</section>
	</Container>

	<Container>
		<section class="home-section">
			<header class="home-section__header">
				<h2>Contact Me</h2>
			</header>
			<p class="contact__message">
				Open to research collaborations and related professional opportunities.
				Feel free to reach out to discuss ideas or connect.
			</p>
			<ul class="contact__list">
				<li>
					<a href="mailto:dkang339@gatech.edu" class="contact__link">
						<Icon name="mdi:email-outline" />
						<span>dkang339@gatech.edu</span>
					</a>
				</li>
				<li>
					<a
						href="https://www.linkedin.com/in/dayoung-kang-7323a828b"
						target="_blank"
						rel="noopener"
						class="contact__link"
					>
						<Icon name="mdi:linkedin" />
						<span>linkedin.com/in/dayoung-kang-7323a828b</span>
					</a>
				</li>
			</ul>
		</section>
	</Container>
</Layout>

<style>
	.hero {
		margin: var(--section-margin) auto;
		display: grid;
		grid-template-columns: minmax(220px, 320px) 1fr;
		gap: 2.5rem;
		align-items: start;
	}
	.hero__photo {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: var(--theme-shape-radius);
		display: block;
	}
	.hero__title {
		margin-top: 0;
		font-size: var(--font-size-xl);
	}
	.hero__title::after,
	.home-section__header h2::after {
		content: '';
		display: block;
		width: 6rem;
		height: 3px;
		background-color: var(--theme-primary);
		margin-top: 0.5rem;
		border-radius: 2px;
	}
	.hero__text p {
		margin: 0 0 1.5rem;
		line-height: 1.7;
	}
	.hero__text p a {
		color: #0066cc;
		text-decoration: underline;
	}
	.hero__text p a:hover {
		color: #004c99;
	}
	.hero__links {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		font-size: var(--font-size-sm);
	}
	.hero__links a {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: inherit;
		text-decoration: none;
	}
	.hero__links a:hover {
		opacity: 0.7;
	}
	.hero__links [data-icon] {
		font-size: 1.1em;
	}
	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			text-align: left;
		}
		.hero__photo {
			max-width: 240px;
		}
	}

	.home-section {
		margin: var(--section-margin) auto;
	}
	.home-section__header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.5rem;
		gap: 1rem;
	}
	.home-section__header h2 {
		margin: 0;
	}
	.home-section__more {
		font-size: var(--font-size-sm);
		opacity: 0.75;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--theme-grid-gap);
	}
	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	.pubs-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.pubs-list__item {
		padding: 1rem 0;
		border-bottom: 1px solid var(--theme-surface-1);
	}
	.pubs-list__item:last-child {
		border-bottom: none;
	}
	.pubs-list__title {
		font-weight: 600;
		font-size: 1.05rem;
	}
	.pubs-list__authors {
		font-size: 0.95rem;
		opacity: 0.8;
		margin-top: 0.25rem;
	}
	.pubs-list__authors :global(.me) {
		font-weight: 700;
		color: var(--theme-primary);
	}
	.pubs-list__venue {
		font-size: 0.9rem;
		opacity: 0.65;
		margin-top: 0.25rem;
	}

	.teaching-list,
	.education-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.teaching-list li,
	.education-list li {
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--theme-surface-1);
	}
	.teaching-list li:last-child,
	.education-list li:last-child {
		border-bottom: none;
	}
	.education {
		margin-top: 2rem;
	}
	.education__title {
		font-size: var(--font-size-md);
		margin: 0 0 0.5rem;
	}
	.education__row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.education__date {
		font-size: var(--font-size-sm);
		opacity: 0.7;
		white-space: nowrap;
	}

	.contact__message {
		font-size: 1.05rem;
		line-height: 1.7;
		margin: 0 0 1.5rem;
	}
	.contact__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.contact__link {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: inherit;
		padding: 0.6rem 1rem;
		background-color: var(--theme-surface-1);
		border-radius: var(--theme-button-border-radius);
		transition: background-color var(--theme-transition);
		width: fit-content;
	}
	.contact__link:hover {
		background-color: var(--theme-surface-2);
	}
	.contact__link [data-icon] {
		font-size: 1.25em;
	}
</style>

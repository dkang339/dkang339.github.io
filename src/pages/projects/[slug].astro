---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { Icon } from 'astro-icon/components';
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

export const getStaticPaths = (async () => {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { project } = Astro.props;
const { title, summary, subtitle, thumbnail, images, videos, pdf, github } = project.data;
const { Content } = await render(project);

const seo = { title: `${title} | Dayoung Kang`, description: summary };
---

<Layout {seo}>
	<Container narrow>
		<article class="project">
			<a class="project__back" href="/projects/">← All projects</a>
			<h1 class="project__title">{title}</h1>
			{subtitle && <p class="project__subtitle">{subtitle}</p>}
			{summary && <p class="project__summary">{summary}</p>}

			<div class="project__links">
				{pdf && (
					<a href={pdf} target="_blank" rel="noopener" class="project__link">
						<Icon name="mdi:file-document-outline" /> View PDF
					</a>
				)}
				{github && (
					<a href={github} target="_blank" rel="noopener" class="project__link">
						<Icon name="mdi:github" /> GitHub
					</a>
				)}
			</div>

			{thumbnail && !videos && (
				<img src={thumbnail} alt={title} class="project__hero" />
			)}

			{videos && videos.length > 0 && (
				<div class="project__videos">
					{videos.map((video) => (
						<figure class="project__video-figure">
							<div class="project__video-frame">
								<video class="project__video" controls muted playsinline preload="metadata">
									<source src={video.src} type="video/mp4" />
								</video>
							</div>
							{video.caption && <figcaption>{video.caption}</figcaption>}
						</figure>
					))}
				</div>
			)}

			{images && images.length > 0 && (
				<div class="project__figures">
					{images.map((img, i) => (
						<img src={img} alt={`${title} figure ${i + 1}`} class="project__figure" />
					))}
				</div>
			)}

			<div class="project__body">
				<Content />
			</div>
		</article>
	</Container>
</Layout>

<style>
	.project {
		margin: var(--section-margin) auto;
	}
	.project__back {
		display: inline-block;
		margin-bottom: 1.5rem;
		font-size: var(--font-size-sm);
		opacity: 0.75;
	}
	.project__title {
		margin: 0 0 0.5rem;
	}
	.project__summary {
		font-size: 1.1rem;
		opacity: 0.8;
		margin: 0 0 1.5rem;
	}
	.project__subtitle {
		margin: 0 0 0.75rem;
		font-size: var(--font-size-sm);
		font-weight: 700;
		color: var(--theme-primary);
	}
	.project__links {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}
	.project__link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: var(--font-size-sm);
		text-decoration: none;
		color: inherit;
		padding: 0.4rem 0.8rem;
		background-color: var(--theme-surface-1);
		border-radius: var(--theme-button-border-radius);
		transition:
			background-color var(--theme-transition),
			color var(--theme-transition);
	}
	.project__link:hover,
	.project__link:focus-visible {
		background-color: var(--theme-primary);
		color: var(--theme-on-primary);
	}
	.project__link [data-icon] {
		font-size: 1.1em;
	}
	.project__hero {
		width: 100%;
		height: auto;
		margin-bottom: 1.5rem;
	}
	.project__videos {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.project__video-figure {
		margin: 0;
	}
	.project__video-frame {
		overflow: hidden;
		aspect-ratio: 4 / 3;
		background-color: var(--theme-surface-2);
	}
	.project__video {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.project__video-figure figcaption {
		margin-top: 0.5rem;
		font-size: var(--font-size-sm);
		line-height: 1.5;
		opacity: 0.8;
	}
	.project__figures {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}
	.project__figure {
		width: 100%;
		height: auto;
	}
	.project__body {
		font-size: 1.05rem;
		line-height: 1.7;
	}
	.project__body :global(p) {
		margin: 0 0 1rem;
	}
	@media (max-width: 700px) {
		.project__videos {
			grid-template-columns: 1fr;
		}
	}
</style>

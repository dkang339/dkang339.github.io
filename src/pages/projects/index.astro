---
import { getCollection } from 'astro:content';
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';

const seo = {
	title: 'Projects | Dayoung Kang',
	description: 'Research projects by Dayoung Kang.',
};

const projects = (await getCollection('projects')).sort(
	(a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
---

<Layout {seo}>
	<Container>
		<section class="page-header">
			<h1>Projects</h1>
			<p>Click a project to see details, figures, and links.</p>
		</section>
		<section class="projects-grid">
			{projects.map((p) => (
				<ProjectCard
					href={`/projects/${p.id}/`}
					imgSrc={p.data.thumbnail}
					title={p.data.title}
					summary={p.data.summary}
					pdf={p.data.pdf}
					github={p.data.github}
				/>
			))}
		</section>
	</Container>
</Layout>

<style>
	.page-header {
		margin: var(--section-margin) auto 2rem;
	}
	.page-header h1::after {
		content: '';
		display: block;
		width: 6rem;
		height: 3px;
		background-color: var(--theme-primary);
		margin-top: 0.5rem;
		border-radius: 2px;
	}
	.projects-grid {
		margin: 0 auto var(--section-margin);
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--theme-grid-gap);
	}
	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

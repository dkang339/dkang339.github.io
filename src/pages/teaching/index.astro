---
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

const seo = {
	title: 'Teaching & Mentoring | Dayoung Kang',
	description: 'Teaching assistantships and research mentoring experience.',
};
---

<Layout {seo}>
	<Container narrow>
		<section class="page-header">
			<h1>Teaching</h1>
		</section>

		<section class="entry">
			<h2>Teaching Assistant — Numerical Analysis and Algorithms</h2>
			<p class="entry__meta">Georgia Institute of Technology • Spring 2024, Spring 2025</p>
			<ul>
				<li>Led exam review sessions</li>
				<li>Developed homework problems and solutions</li>
				<li>Guided students through weekly in-class problem-solving activities</li>
			</ul>
		</section>

		<section class="entry">
			<h2>Teaching Assistant — Introduction to IoT-based Digital Twin</h2>
			<p class="entry__meta">Pusan National University • Fall 2022</p>
			<ul>
				<li>Led lectures on mesh generation with Cubit, structural simulation with Akselos, and introduction to fatigue analysis</li>
				<li>Developed homework problems and solutions</li>
			</ul>
		</section>

		<section class="page-header">
			<h1>Mentoring</h1>
		</section>

		<section class="entry">
			<h2>Research Mentor — Multifidelity Neural Network Project</h2>
			<p class="entry__meta">Fall 2024 – Fall 2025</p>
			<ul>
				<li>
					Mentor for Georgia Tech
					<a href="https://undergradresearch.gatech.edu/content/presidents-undergraduate-research-awards" target="_blank" rel="noopener">President's Undergraduate Research Award (PURA)</a>
				</li>
				<li>Mentored an undergraduate student in developing neural network models with multifidelity data</li>
				<li>Guided theory and development of multifidelity neural networks</li>
			</ul>
		</section>

		<section class="entry">
			<h2>Research Mentor — Multifidelity Linear Regression Project</h2>
			<p class="entry__meta">Summer 2025</p>
			<ul>
				<li>
					Mentor for Georgia Tech's
					<a href="https://sure.gatech.edu/about-sure" target="_blank" rel="noopener">Summer Undergraduate Research in Engineering (SURE)</a>
					program
				</li>
				<li>Mentored an undergraduate student in implementing multifidelity models for uncertainty quantification</li>
				<li>Guided theory and implementation of multifidelity Monte Carlo and multifidelity linear regression methods</li>
			</ul>
		</section>
	</Container>
</Layout>

<style>
	.page-header {
		margin: var(--section-margin) auto 1rem;
	}
	.page-header h1::after {
		content: '';
		display: block;
		width: 6rem;
		height: 3px;
		background-color: var(--theme-primary);
		margin-top: 0.5rem;
		border-radius: 2px;
	}
	.entry {
		margin: 0 auto 2rem;
	}
	.entry h2 {
		font-size: 1.2rem;
		margin: 0 0 0.25rem;
	}
	.entry__meta {
		font-size: var(--font-size-sm);
		opacity: 0.7;
		margin: 0 0 0.75rem;
	}
	.entry ul {
		margin: 0;
		padding-left: 1.25rem;
		line-height: 1.7;
	}
</style>
